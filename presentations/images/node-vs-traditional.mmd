flowchart TB
    subgraph Traditional["Traditional Server (e.g., Java Servlet)"]
        direction TB
        R1["Request 1"] --> T1["Thread 1"]
        R2["Request 2"] --> T2["Thread 2"]
        R3["Request 3"] --> T3["Thread 3"]
        R4["Request 4"] --> T4["Waiting...<br/>(no free thread)"]
    end
    subgraph NodeJS["Node.js Server"]
        direction TB
        R5["Request 1"] --> EL2["Event Loop<br/>(Single Thread)"]
        R6["Request 2"] --> EL2
        R7["Request 3"] --> EL2
        R8["Request 4"] --> EL2
    end
    style Traditional fill:#FFEBEE,stroke:#C62828
    style NodeJS fill:#E8F5E9,stroke:#2E7D32
    style T4 fill:#f44336,color:#fff
