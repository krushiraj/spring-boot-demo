        direction LR
        B1["Browser"] -->|"Request /page1"| S1["Server"]
        S1 -->|"Full HTML"| B1
        B1 -->|"Request /page2"| S1
        S1 -->|"Full HTML"| B1
    end
    subgraph SPA["Single Page Application (React)"]
        direction LR
        B2["Browser"] -->|"Request / (once)"| S2["Server"]
